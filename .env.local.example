# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored — never commit it.

# Anthropic API key for the recipe converter (server-side only)
ANTHROPIC_API_KEY=sk-ant-api03-...

# USDA FoodData Central API key for nutrition lookups (used in v2)
USDA_API_KEY=...

# Supabase service-role key (server-side only — bypasses RLS).
# Required for /api/convert rate limiting. Find it in Supabase Dashboard
# → Project Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=eyJ...
